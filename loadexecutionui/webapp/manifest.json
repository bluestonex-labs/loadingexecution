{
  "_version": "1.65.0",
  "sap.app": {
    "id": "com.sysco.wm.loadexecutionui",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.18.0",
      "toolsId": "e485beaf-f205-443b-a2aa-1f28d4ddc650"
    },
    "crossNavigation": {
      "inbounds": {
        "Loading_Execution-Display": {
          "semanticObject": "Loading_Execution",
          "action": "Display",
          "title": "{{Loading_Execution-Display.flpTitle}}",
          "icon": "sap-icon://BusinessSuiteInAppSymbols/icon-stock-warehouse",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    },
    "dataSources": {
      "mainService": {
        "uri": "/cloudWMService/CloudWM/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "localUri": "localService/CloudWM/metadata.xml",
          "odataVersion": "4.0"
        }
      },
      "Loading": {
        "uri": "/cloudWMService/Loading/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "localUri": "localService/Loading/metadata.xml",
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.136.2",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "contentDensities": {
      "compact": false,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.sysco.wm.loadexecutionui.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "Loading": {
        "dataSource": "Loading",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "com.sysco.wm.loadexecutionui.view",
        "async": true,
        "viewPath": "com.sysco.wm.loadexecutionui.view"
      },
      "routes": [
        {
          "name": "RouteView1",
          "pattern": ":?query:",
          "target": [
            "TargetView1"
          ]
        },
        {
          "name": "loadTypes",
          "pattern": "loadTypes",
          "target": [
            "loadTypes"
          ]
        },
        {
          "name": "shuttle",
          "pattern": "shuttle/{routeID}/{load}",
          "target": [
            "shuttle"
          ]
        },
        {
          "name": "pallets",
          "pattern": "pallets/{checkRouteField}/{Plant}/{Route}/{vehicle}",
          "target": [
            "pallets"
          ]
        }
      ],
      "targets": {
        "TargetView1": {
          "viewType": "XML",
          "name": "View1"
        },
        "loadTypes": {
          "viewType": "XML",
          "name": "loadTypes"
        },
        "shuttle": {
          "viewType": "XML",
          "name": "shuttle"
        },
        "pallets": {
          "viewType": "XML",
          "name": "pallets"
        }
      }
    },
    "rootView": {
      "viewName": "com.sysco.wm.loadexecutionui.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  },
  "sap.cloud": {
    "public": true,
    "service": "LoadingExecution"
  }
}
