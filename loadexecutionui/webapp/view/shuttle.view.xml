<mvc:View xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:tnt="sap.tnt" xmlns:core="sap.ui.core" controllerName="com.sysco.wm.loadexecutionui.controller.shuttle">
    <Page title="{i18n>title}" showHeader="false" showFooter="false">
        <HBox width="100%" height="100%">
            <VBox width="50%" alignItems="Center" alignContent="Center" justifyContent="Center">
                <Button id="shuttleid" class="largeWidth blackButton sapUiSmallMarginBottom" text="" enabled="false"/>
                <Button id="routeid" class="largeWidth blackButton sapUiSmallMarginBottom" text="{i18n>route}" enabled="false"/>
            </VBox>
            <VBox width="50%" alignItems="Center" alignContent="Center" justifyContent="Center" class="responsiveBox">
                    <Title text="{i18n>vehicleID}" id="idSuggestionsSearch" width="12rem"/>
                    <Input id="productInput" width="12rem" placeholder="{i18n>vehicleIDSuggest}" showSuggestion="true" suggest=".onSuggest" suggestionItems="{vehIdMod>/}" suggestionItemSelected=".onSuggestionItemSelected">
                    <suggestionItems>
                        <core:Item text="{vehIdMod>VEHICLEID}"/>
                    </suggestionItems>
                </Input>
                <Button text="{i18n>confirm}" press="onVehicleConfirm" class="largeWidth blackButton tallButton"/>
            </VBox>
        </HBox>
    </Page>
</mvc:View>